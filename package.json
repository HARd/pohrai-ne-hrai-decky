{
  "name": "decky-pohrai-ne-hrai",
  "version": "0.4.2",
  "description": "Decky Loader plugin that marks Ukrainian and hostile developers in the Steam Deck interface.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "watch": "rollup -c -w",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "decky",
    "steam-deck",
    "steam",
    "ukraine"
  ],
  "author": "POHRAI/NE HRAI contributors",
  "license": "MIT",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "react-router": "^7.15.1",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
